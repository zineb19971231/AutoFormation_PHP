        <attribute name="edited" value="cmlkYWs7TEFQVE9QLUxVUDQ5MU4wOzIwMjYtMDMtMDU7IjEyOjI3OjU3ICI7MTsyODYy"/>
    </attributes>
    <function name="Main" type="None" variable="">
        <parameters/>
        <body>
            <declare name="age" type="Integer" array="False" size=""/>
            <if expression="age &lt; 12">
                <then>
                    <output expression="&quot;the price is 20DH + BONUS special chlidren's Menu included !&quot;" newline="False"/>
                </then>
                <else>
                    <if expression="age &gt; 12 &amp;&amp; age &lt; 18">
                        <then>
                            <output expression="&quot;the price is 40 dh &quot;" newline="True"/>
                        </then>
                        <else>
                            <if expression="age &gt; 60">
                                <then>
                                    <output expression="&quot;the price is 30 dh&quot;" newline="True"/>
                                </then>
                                <else/>
                            </if>
                        </else>
                    </if>
                    <output expression="&quot;the price is 60 dh&quot;" newline="True"/>
                </else>
            </if>
        </body>
    </function>
</flowgorithm>
